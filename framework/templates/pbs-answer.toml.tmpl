# PBS automated installation answer file.
# Generated by install-pbs.sh from config.yaml and SOPS secrets.
# See: https://pve.proxmox.com/wiki/Automated_Installation

[global]
keyboard = "en-us"
country = "us"
fqdn = "PBS_FQDN"
mailto = "PBS_MAILTO"
timezone = "PBS_TIMEZONE"
root-password = "PBS_ROOT_PASSWORD"
reboot-mode = "power-off"

[network]
source = "from-answer"
cidr = "PBS_CIDR"
dns = "PBS_DNS"
gateway = "PBS_GATEWAY"

[network.filter]
ID_NET_NAME = "ens*"

[disk-setup]
filesystem = "ext4"
disk-list = ["sda"]
