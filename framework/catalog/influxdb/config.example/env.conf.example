# InfluxDB 2.x environment variable overrides (REQUIRED)
#
# These are passed to the influxd process as environment variables.
# See: https://docs.influxdata.com/influxdb/v2/reference/config-options/
#
# TLS settings are injected automatically by the catalog module —
# do NOT set INFLUXD_TLS_CERT or INFLUXD_TLS_KEY here.

INFLUXD_BOLT_PATH=/var/lib/influxdb2/influxd.bolt
INFLUXD_ENGINE_PATH=/var/lib/influxdb2/engine
INFLUXD_HTTP_BIND_ADDRESS=:8086

# Tune WAL fsync delay for better write throughput (default: 0ms)
# INFLUXD_STORAGE_WAL_FSYNC_DELAY=100ms

# Add any InfluxDB configuration here — the framework passes it through.
